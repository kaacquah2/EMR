# Production Docker environment — copy to .env.docker and fill in real values.
# NEVER commit .env.docker to version control.
#
# Usage:
#   cp .env.docker.example .env.docker
#   # Fill in all required values
#   docker compose up -d

# ─── Required secrets ────────────────────────────────────────────────────────
SECRET_KEY=replace-with-openssl-rand-hex-32
FIELD_ENCRYPTION_KEY=replace-with-openssl-rand-hex-32
AUDIT_LOG_SIGNING_KEY=replace-with-openssl-rand-hex-32

POSTGRES_DB=medsync
POSTGRES_USER=postgres
POSTGRES_PASSWORD=replace-with-strong-db-password

# ─── Application settings ────────────────────────────────────────────────────
DEBUG=False
ENV=production
ALLOWED_HOSTS=your-domain.com,www.your-domain.com

# Non-guessable admin path — generate: python -c "import secrets; print('ms-admin-' + secrets.token_hex(4) + '/')"
ADMIN_URL=ms-admin-changeme/

# ─── CORS & CSRF ─────────────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=https://your-frontend-domain.com
CSRF_TRUSTED_ORIGINS=https://your-frontend-domain.com

# ─── Frontend URLs ───────────────────────────────────────────────────────────
FRONTEND_URL=https://your-frontend-domain.com
PASSWORD_RESET_FRONTEND_URL=https://your-frontend-domain.com/auth/reset-password
NEXT_PUBLIC_API_URL=https://your-api-domain.com/api/v1

# ─── WebAuthn / Passkey ──────────────────────────────────────────────────────
WEBAUTHN_RP_ID=your-frontend-domain.com
WEBAUTHN_ORIGIN=https://your-frontend-domain.com
WEBAUTHN_ENABLED=True

# ─── Email (MFA OTP + password reset) ───────────────────────────────────────
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-smtp-user
EMAIL_HOST_PASSWORD=your-smtp-password
DEFAULT_FROM_EMAIL=MedSync EMR <noreply@your-domain.com>
SUPPORT_EMAIL=support@your-domain.com

# ─── Security ────────────────────────────────────────────────────────────────
SECURE_HTTPS=True
SECURE_HSTS_SECONDS=31536000

# ─── Sentry error tracking (optional) ───────────────────────────────────────
# SENTRY_DSN=https://your-key@sentry.io/project-id
# SENTRY_TRACES_SAMPLE_RATE=0.1
# SENTRY_RELEASE=1.0.0

# ─── NHIS integration (optional) ─────────────────────────────────────────────
# NHIS_API_BASE_URL=https://api.nhia.gov.gh/v2
# NHIS_API_KEY=your-facility-api-key
# NHIS_FACILITY_CODE=your-nhis-facility-code

# ─── Discharge summary AI (optional, costs money) ────────────────────────────
# LLM_MODE=bedrock
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=eu-north-1
# BEDROCK_MODEL_ID=eu.anthropic.claude-sonnet-4-6

# ─── Monitoring ──────────────────────────────────────────────────────────────
# BACKUP_ENABLED=True
# BACKUP_MAX_AGE_HOURS=26
LOG_LEVEL=INFO
