# Copy to .env and set values. Never commit .env.
# See README "Environment" section for full descriptions.

# Required in production
SECRET_KEY=your-secret-key-set-in-production
# DATABASE_URL=postgresql://USER:PASSWORD@HOST/DB?sslmode=require

# Local dev without Neon/Postgres: leave DATABASE_URL unset (or omit it) and set DEBUG=True.
# Then migrate/setup_dev/runserver use SQLite (db.sqlite3). If DATABASE_URL is set, Postgres is used and must be reachable.
# Local dev (optional; defaults below)
# DEBUG=True
# ALLOWED_HOSTS=localhost,127.0.0.1
# CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Production enforcement
# ENV=production
# SECURE_HTTPS=True
# SECURE_HSTS_SECONDS=31536000
# CSRF_TRUSTED_ORIGINS=https://app.example.com
# CORS_ALLOWED_ORIGINS=https://app.example.com

# JWT (optional; defaults: 15 min access, 7 days refresh)
# JWT_ACCESS_MINUTES=15
# JWT_REFRESH_DAYS=7

# Throttling (optional)
# THROTTLE_ANON=60/hour
# THROTTLE_USER=1000/hour

# RBAC Fail-Closed Mode (CRITICAL SECURITY SETTING)
# Default: False (fail-open, safe for development)
# Production: Set to True ONLY after RBAC coverage is verified at 100%
# See README.md section "RBAC Security: Fail-Closed Mode" for complete runbook
# When enabled: unknown API endpoints return 403 instead of 404
# When disabled: unknown endpoints pass through to 404 (permissive, for debugging)
# PERMISSION_FAIL_CLOSED_UNKNOWN_ENDPOINTS=False

# Field encryption key for sensitive patient data
# FIELD_ENCRYPTION_KEY=replace-with-generated-fernet-key

# Dev-only permission bypass (DEBUG only). Comma-separated email allowlist.
# DEV_PERMISSION_BYPASS_EMAILS=admin@medsync.gh,doctor@medsync.gh,doctor2@medsync.gh,hospital_admin@medsync.gh,nurse@medsync.gh,receptionist@medsync.gh,lab_technician@medsync.gh

# Email — dev default is console (prints to logs only; nothing is delivered).
# Production (Railway, Vercel, etc.): you must configure real SMTP below, or MFA email OTP and
# password-reset emails will not reach users (SendGrid, Mailgun, SES, Gmail, etc.).

# Optional: leave EMAIL_BACKEND unset if you set SMTP host + user + password — the app will use SMTP.
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# DEFAULT_FROM_EMAIL=MedSync <noreply@yourdomain.com>
# EMAIL_HOST=smtp.example.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=True
# EMAIL_USE_SSL=False
# For port 465 SSL, use EMAIL_USE_SSL=True and typically EMAIL_USE_TLS=False
# EMAIL_HOST_USER=
# EMAIL_HOST_PASSWORD=

# Gmail SMTP (use App Password: https://myaccount.google.com/apppasswords)
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=True
# EMAIL_HOST_USER=your@gmail.com
# EMAIL_HOST_PASSWORD=your-16-char-app-password
# DEFAULT_FROM_EMAIL=MedSync EMR <your@gmail.com>

# Activation flow — frontend route must match your deployed app (HTTPS)
# FRONTEND_URL=https://your-app.vercel.app
# Password Reset — frontend route must match your deployed app (HTTPS)
# PASSWORD_RESET_FRONTEND_URL=https://your-app.vercel.app/auth/reset-password
# PASSWORD_RESET_TOKEN_EXPIRY_HOURS=24

# Support email — used in invitation emails for help/support contact
# SUPPORT_EMAIL=support@hospital.gh

# Break-glass notifications (optional)
# BREAK_GLASS_NOTIFY_EMAILS=admin@example.com

# Redis (Celery + optional Channels WebSocket layer). Use a full URI, not host:port only.
# REDIS_URL=redis://default:PASSWORD@your-host.cloud.redislabs.com:PORT/0
# CELERY_BROKER_URL=redis://default:PASSWORD@your-host.cloud.redislabs.com:PORT/0
# CELERY_RESULT_BACKEND=redis://default:PASSWORD@your-host.cloud.redislabs.com:PORT/0
# If unset, Celery defaults to redis://127.0.0.1:6379/0; Channels uses in-memory layer unless REDIS_URL is set.

# WebAuthn / Passkey Configuration
# Enables passkey (fingerprint/face ID) authentication for MedSync PWA
# Development: use localhost; Production: use your app domain (without https://)
# WEBAUTHN_RP_ID=localhost                          # Relying party identifier (your domain, no protocol)
# WEBAUTHN_ORIGIN=http://localhost:3000             # Must match frontend URL exactly (with scheme)
# WEBAUTHN_ENABLED=True                             # Master switch for passkey authentication

# Phase 3: AI Model Configuration
# AI_MODEL_VERSION: Version of trained models to use (default: 1.0.0-hybrid)
# Available versions from training pipeline: 1.0.0-synthetic, 1.0.0-uci, 1.0.0-hybrid, 1.0.0-mimic, 1.0.0-kaggle
# AI_MODEL_VERSION=1.0.0-hybrid

# AI_MODELS_TRAINED_ON_REAL_DATA: Flag indicating if models are trained on realistic/public data (not just rule-based)
# Set to true when using: UCI, MIMIC-IV, Kaggle, or hybrid datasets
# AI_MODELS_TRAINED_ON_REAL_DATA=true

# MEDSYNC_AI_MODELS_DIR: Directory where trained models are stored (joblib format)
# Default: api/ai/models/ (relative to Django BASE_DIR)
# MEDSYNC_AI_MODELS_DIR=api/ai/models

# Hospital AI Deployment Gates (optional per-hospital override)
# DISABLE_AI_CLINICAL_FEATURES: Circuit breaker to completely disable all clinical AI features
# Default: true (all AI features disabled until explicitly enabled for hospital)
# Set to false in production ONLY when hospital has approved AI and models are validated
# DISABLE_AI_CLINICAL_FEATURES=true

# AI_CLINICAL_FEATURES_ENABLED: Global circuit breaker for all clinical AI features
# Default: false (all AI features disabled until hospital explicitly approves)
# AI_CLINICAL_FEATURES_ENABLED=false

# AI_CONFIDENCE_THRESHOLD_CLINICAL: Minimum confidence score for AI predictions in production
# Default: 0.80 (80% confidence required)
# Clinical deployment requires 80% confidence minimum for patient safety
# AI_CONFIDENCE_THRESHOLD_CLINICAL=0.80

