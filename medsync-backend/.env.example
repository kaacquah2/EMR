# Copy to .env and set values. Never commit .env.
# See README "Environment" section for full descriptions.

# Required in production
SECRET_KEY=your-secret-key-set-in-production
# DATABASE_URL=postgresql://USER:PASSWORD@HOST/DB?sslmode=require

# Local dev without Neon/Postgres: leave DATABASE_URL unset (or omit it) and set DEBUG=True.
# Then migrate/setup_dev/runserver use SQLite (db.sqlite3). If DATABASE_URL is set, Postgres is used and must be reachable.
# Local dev (optional; defaults below)
# DEBUG=True
# ALLOWED_HOSTS=localhost,127.0.0.1
# CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Production enforcement
# ENV=production
# SECURE_HTTPS=True
# SECURE_HSTS_SECONDS=31536000
# CSRF_TRUSTED_ORIGINS=https://app.example.com
# CORS_ALLOWED_ORIGINS=https://app.example.com

# JWT (optional; defaults: 15 min access, 7 days refresh)
# JWT_ACCESS_MINUTES=15
# JWT_REFRESH_DAYS=7

# Throttling (optional)
# THROTTLE_ANON=60/hour
# THROTTLE_USER=1000/hour
# PERMISSION_FAIL_CLOSED_UNKNOWN_ENDPOINTS=True
# FIELD_ENCRYPTION_KEY=replace-with-generated-fernet-key

# Dev-only permission bypass (DEBUG only). Comma-separated email allowlist.
# DEV_PERMISSION_BYPASS_EMAILS=admin@medsync.gh,doctor@medsync.gh,doctor2@medsync.gh,hospital_admin@medsync.gh,nurse@medsync.gh,receptionist@medsync.gh,lab_technician@medsync.gh

# Email — dev default is console (prints to logs only; nothing is delivered).
# Production (Railway, Vercel, etc.): you must configure real SMTP below, or MFA email OTP and
# password-reset emails will not reach users (SendGrid, Mailgun, SES, Gmail, etc.).

# Optional: leave EMAIL_BACKEND unset if you set SMTP host + user + password — the app will use SMTP.
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# DEFAULT_FROM_EMAIL=MedSync <noreply@yourdomain.com>
# EMAIL_HOST=smtp.example.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=True
# EMAIL_USE_SSL=False
# For port 465 SSL, use EMAIL_USE_SSL=True and typically EMAIL_USE_TLS=False
# EMAIL_HOST_USER=
# EMAIL_HOST_PASSWORD=

# Gmail SMTP (use App Password: https://myaccount.google.com/apppasswords)
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=True
# EMAIL_HOST_USER=your@gmail.com
# EMAIL_HOST_PASSWORD=your-16-char-app-password
# DEFAULT_FROM_EMAIL=MedSync EMR <your@gmail.com>

# Password Reset — frontend route must match your deployed app (HTTPS)
# PASSWORD_RESET_FRONTEND_URL=https://your-app.vercel.app/reset-password
# PASSWORD_RESET_TOKEN_EXPIRY_HOURS=24

# Break-glass notifications (optional)
# BREAK_GLASS_NOTIFY_EMAILS=admin@example.com

# Redis (Celery + optional Channels WebSocket layer). Use a full URI, not host:port only.
# REDIS_URL=redis://default:PASSWORD@your-host.cloud.redislabs.com:PORT/0
# CELERY_BROKER_URL=redis://default:PASSWORD@your-host.cloud.redislabs.com:PORT/0
# CELERY_RESULT_BACKEND=redis://default:PASSWORD@your-host.cloud.redislabs.com:PORT/0
# If unset, Celery defaults to redis://127.0.0.1:6379/0; Channels uses in-memory layer unless REDIS_URL is set.
