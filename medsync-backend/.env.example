# Copy to .env and set values. Never commit .env.
# See README "Environment" section for full descriptions.

DEBUG=True
ENV=development
SECRET_KEY=replace-with-a-long-random-secret-key
FIELD_ENCRYPTION_KEY=replace-with-a-32-byte-hex-or-url-safe-key
AUDIT_LOG_SIGNING_KEY=replace-with-a-long-random-audit-signing-key
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/medsync
ALLOWED_HOSTS=localhost,127.0.0.1
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
FRONTEND_URL=http://localhost:3000
PASSWORD_RESET_FRONTEND_URL=http://localhost:3000/auth/reset-password
SUPPORT_EMAIL=support@medsync.gh

# Production enforcement
# ENV=production
# SECURE_HTTPS=True
# SECURE_HSTS_SECONDS=31536000
# CSRF_TRUSTED_ORIGINS=https://app.example.com
# CORS_ALLOWED_ORIGINS=https://app.example.com

# JWT (optional; defaults: 15 min access, 7 days refresh)
# JWT_ACCESS_MINUTES=15
# JWT_REFRESH_DAYS=7

# MFA OTP expiry window in minutes (default: 10). Increase for busy clinical settings.
# MFA_OTP_EXPIRY_MINUTES=10

# Throttling (optional)
# THROTTLE_ANON=60/hour
# THROTTLE_USER=1000/hour

# RBAC Fail-Closed Mode
# Default: True (deny unknown endpoints). Set to False only when debugging RBAC gaps.
# PERMISSION_FAIL_CLOSED_UNKNOWN_ENDPOINTS=True

# Non-guessable Django admin path — REQUIRED in production (startup will fail if left as admin/).
# Generate: python -c "import secrets; print('ms-admin-' + secrets.token_hex(4) + '/')"
# ADMIN_URL=ms-admin-x7k2/

# Backup monitoring (health endpoint reports not_configured until a run is recorded)
# BACKUP_ENABLED=True
# BACKUP_MAX_AGE_HOURS=26

# Structured logging level (DEBUG, INFO, WARNING)
# LOG_LEVEL=INFO

# Dev-only permission bypass (DEBUG only). Comma-separated email allowlist.
# DEV_PERMISSION_BYPASS_EMAILS=

# Email — dev default is console (prints to logs only; nothing is delivered).
# Production (Railway, Vercel, etc.) & live demo testing: you must configure a real SMTP provider, 
# or MFA email OTP and password-reset emails will not reach users.

# Set EMAIL_BACKEND explicitly to SMTP when configuring credentials:
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend

# 1. Mailtrap Sandbox (Recommended for Dev & Demo Testing)
# EMAIL_HOST=sandbox.smtp.mailtrap.io
# EMAIL_PORT=2525
# EMAIL_USE_TLS=True
# EMAIL_USE_SSL=False
# EMAIL_HOST_USER=your_mailtrap_username
# EMAIL_HOST_PASSWORD=your_mailtrap_password
# DEFAULT_FROM_EMAIL=MedSync EMR <noreply@medsync.gh>

# 2. SendGrid Configuration
# EMAIL_HOST=smtp.sendgrid.net
# EMAIL_PORT=587
# EMAIL_USE_TLS=True
# EMAIL_USE_SSL=False
# EMAIL_HOST_USER=apikey
# EMAIL_HOST_PASSWORD=your_sendgrid_api_key
# DEFAULT_FROM_EMAIL=MedSync EMR <your_verified_sender@domain.com>

# 3. Mailgun Configuration
# EMAIL_HOST=smtp.mailgun.org
# EMAIL_PORT=587
# EMAIL_USE_TLS=True
# EMAIL_USE_SSL=False
# EMAIL_HOST_USER=postmaster@your_mailgun_domain.com
# EMAIL_HOST_PASSWORD=your_mailgun_smtp_password
# DEFAULT_FROM_EMAIL=MedSync EMR <noreply@your_mailgun_domain.com>

# 4. Gmail SMTP (use App Password: https://myaccount.google.com/apppasswords)
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=True
# EMAIL_USE_SSL=False
# EMAIL_HOST_USER=your@gmail.com
# EMAIL_HOST_PASSWORD=your-16-char-app-password
# DEFAULT_FROM_EMAIL=MedSync EMR <your@gmail.com>

# Activation flow — frontend route must match your deployed app (HTTPS)
# FRONTEND_URL=https://your-app.vercel.app
# Password Reset — frontend route must match your deployed app (HTTPS)
# PASSWORD_RESET_FRONTEND_URL=https://your-app.vercel.app/auth/reset-password
# PASSWORD_RESET_TOKEN_EXPIRY_HOURS=24

# Support email — used in invitation emails for help/support contact
# SUPPORT_EMAIL=support@hospital.gh

# Break-glass notifications (optional)
# BREAK_GLASS_NOTIFY_EMAILS=admin@example.com

# Sentry error tracking (optional — leave blank to disable)
# SENTRY_DSN=https://xxxx@oyyy.ingest.sentry.io/zzzz

# WebAuthn / Passkey Configuration
# Enables passkey (fingerprint/face ID) authentication for MedSync PWA
# Development: use localhost; Production: use your app domain (without https://)
# WEBAUTHN_RP_ID=localhost                          # Relying party identifier (your domain, no protocol)
# WEBAUTHN_ORIGIN=http://localhost:3000             # Must match frontend URL exactly (with scheme)
# WEBAUTHN_ENABLED=True                             # Master switch for passkey authentication
