{
  "venvPath": ".",
  "venv": ".venv",
  "reportMissingImports": "warning",
  "reportAttributeAccessIssue": "none",
  "typeCheckingMode": "basic",
  "pythonVersion": "3.13",
  "exclude": [
    "**/migrations/**",
    "**/__pycache__/**",
    "**/node_modules/**"
  ],
  "plugins": [
    "mypy_django_plugin.main"
  ]
}