# docker-compose environment — copy this file and fill in real values before running.
# DO NOT commit real secrets to version control.
# Generate secrets: python -c "import secrets; print(secrets.token_urlsafe(32))"

# ── Postgres ──────────────────────────────────────────────────────────────────
POSTGRES_DB=medsync
POSTGRES_USER=postgres
POSTGRES_PASSWORD=CHANGE_ME_strong_password

# ── Django ────────────────────────────────────────────────────────────────────
DEBUG=False
ENV=development
SECRET_KEY=CHANGE_ME_use_openssl_rand_hex_32

# ── AI / LLM ──────────────────────────────────────────────────────────────────
# Set to "bedrock" (or your real provider) before deploying to production.
LLM_MODE=mock

# ── Security ──────────────────────────────────────────────────────────────────
FIELD_ENCRYPTION_KEY=CHANGE_ME_use_openssl_rand_hex_32
AUDIT_LOG_SIGNING_KEY=CHANGE_ME_use_openssl_rand_hex_32

# ── Allowed hosts / CORS ──────────────────────────────────────────────────────
ALLOWED_HOSTS=localhost,127.0.0.1
CORS_ALLOWED_ORIGINS=http://localhost:3000

# ── Frontend ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
