# EMR root .gitignore (when this directory is the repo root)
# Prevents committing artifacts that may appear at root level.

.env
.env.*
!.env.example
*.sqlite3
.venv/
venv/
media/
# ML Models & Data
*.joblib
medsync-backend/api/ai/models/*
!medsync-backend/api/ai/models/.gitkeep
medsync-backend/data/datasets/
__pycache__/
*.pyc
node_modules/
.next/
out/
build/
dist/
*.egg-info/

# Playwright
test-results/
playwright-report/
blob-report/
playwright/.cache/

# Local debug artifacts (do not commit)
medsync-frontend/ts_errors*.txt
medsync-backend/test_run_output.txt
