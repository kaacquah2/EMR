# EMR root .gitignore (when this directory is the repo root)
# Prevents committing artifacts that may appear at root level.

.env
.env.*
!.env.example
!.env.docker
!.env.docker.example
*.sqlite3
.venv/
venv/
media/
# ML model artefacts (AI module has been removed)
*.joblib
__pycache__/
*.pyc
node_modules/
.next/
out/
build/
dist/
*.egg-info/

# Playwright
test-results/
playwright-report/
blob-report/
playwright/.cache/

# Local debug / scratch artifacts (do not commit)
medsync-frontend/ts_errors*.txt
medsync-backend/test_run_output.txt
medsync-backend/*_results.txt
medsync-backend/test_*.txt
medsync-backend/SETUP_COMPLETE.txt
medsync-backend/db.sqlite3
MedSync_EMR_Master_Prompt.md
spec_extracted.txt
